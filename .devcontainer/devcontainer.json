	"image": "mcr.microsoft.com/vscode/devcontainers/base:debian",

	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2.16.1": {
			"moby": false
		},
		"ghcr.io/devcontainers/features/php:1": {},
		"ghcr.io/devcontainers/features/python:1": {},
